# ── Privacy boundary (RISKS P-01, ADR-0007) ─────────────────────────────
# Real career data NEVER enters this public repo. The committed
# docs/profile.example/ (fictional) is used by tests, fixtures, and demos.
docs/profile/

# Secrets — .env.example (documented variable names only) is committed
.env
.env.*
!.env.example

# Local data: database dumps, backups, exports of real postings/applications.
# Dumps of dev contain real profile rows — no dump naming variant may ever be
# commit-eligible. /*.sql only ignores repo-root files (a plain-format pg_dump
# landing there); committed migrations live under packages/db/migrations/.
*.dump
*.backup
*.sql.gz
/*.sql
backups/
exports/

# ── Dependencies & build output ──────────────────────────────────────────
node_modules/
dist/
# `nuxt generate` drops a convenience symlink `dist -> .output/public` at the
# app root; the `dist/` rule above matches directories only, so name the link.
apps/*/dist
.output/
.nuxt/
.nitro/
# Nuxt Content's build-time SQLite database (regenerated every build).
.data/
coverage/
*.tsbuildinfo

# ── OS / editor noise ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/*
!.vscode/extensions.json
# settings.json is deliberately committed: mechanism B (RISKS S-03) hides
# .env from the editor surface and must survive fresh clones.
!.vscode/settings.json

# ── Playwright run artifacts (e2e traces may embed rendered pages) ──────
test-results/
playwright-report/
