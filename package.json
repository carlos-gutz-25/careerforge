{
  "name": "careerforge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @careerforge-app/api dev",
    "dev:web": "pnpm --filter @careerforge-app/web dev",
    "dev:portfolio": "pnpm --filter @careerforge-app/portfolio dev",
    "generate:portfolio": "pnpm --filter @careerforge-app/portfolio generate",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @careerforge/db run generate",
    "db:migrate": "pnpm --filter @careerforge/db run migrate",
    "db:seed": "pnpm --filter @careerforge/db run seed",
    "profile:import": "pnpm --filter @careerforge-app/api run profile:import",
    "auth:sync-bootstrap": "pnpm --filter @careerforge-app/api run auth:sync-bootstrap",
    "extraction:verify-quotes": "pnpm --filter @careerforge-app/api run extraction:verify-quotes",
    "openapi:generate": "pnpm --filter @careerforge-app/api run openapi:generate",
    "llm:smoke": "pnpm --filter @careerforge/llm run smoke",
    "llm:adversarial-smoke": "pnpm --filter @careerforge/llm run adversarial-smoke",
    "llm:drafting-adversarial-smoke": "pnpm --filter @careerforge/llm run drafting-adversarial-smoke",
    "test:e2e": "pnpm --filter @careerforge-app/web run test:e2e"
  },
  "devDependencies": {
    "@careerforge/config": "workspace:*",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
