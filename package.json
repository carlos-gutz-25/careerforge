{
  "name": "careerforge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @careerforge-app/api dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@careerforge/config": "workspace:*",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
