{
  // Nuxt convention (deviation from @careerforge/config/tsconfig.base.json,
  // documented in README.md): the generated .nuxt/tsconfig.json carries the
  // app aliases + strict settings; `nuxt typecheck` regenerates it before
  // running vue-tsc, so a fresh clone typechecks without a manual prepare.
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    // The monorepo imports with explicit .ts extensions (Node type-stripping,
    // tsconfig.base.json `module: preserve`); vue-tsc type-checks the
    // imported @careerforge/core sources, so it needs the same allowance.
    // Safe here: vue-tsc runs --noEmit only.
    "allowImportingTsExtensions": true
  }
}
