# CareerForge environment — copy to .env and fill in values:  cp .env.example .env
# .env is gitignored; NEVER commit real values. Safe local defaults only here.
#
# API variables are zod-validated at boot (apps/api/src/env.ts — the single
# source of truth; a test asserts every schema key is documented in this file).

# ── Postgres (docker compose) ────────────────────────────────────────────
POSTGRES_USER=careerforge
POSTGRES_PASSWORD=generate-a-local-password
POSTGRES_DB=careerforge
POSTGRES_PORT=5432

# ── apps/api ─────────────────────────────────────────────────────────────
# development | test | production
NODE_ENV=development
API_PORT=3001
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Must match the POSTGRES_* values above.
DATABASE_URL=postgres://careerforge:generate-a-local-password@localhost:5432/careerforge
# Integration tests NEVER use DATABASE_URL directly: they derive it with the
# database name suffixed `_test` (careerforge_test), creating that DB on the
# same server as needed. Uncomment only to point tests somewhere else.
# TEST_DATABASE_URL=

# ── auth (M0-07, ADR-0007) ──────────────────────────────────────────────
# The single user, created at first boot iff no user has this email.
# NOTE: changing AUTH_BOOTSTRAP_PASSWORD later does NOT update the existing
# user — the value is only read when the user is first created. Min 12 chars.
AUTH_BOOTSTRAP_EMAIL=you@example.com
AUTH_BOOTSTRAP_PASSWORD=generate-a-strong-password
# Browser origin allowed on mutating requests (CSRF origin check); apps/web
# dev server. Also the CORS origin once M0-10 lands.
WEB_APP_ORIGIN=http://localhost:3000
