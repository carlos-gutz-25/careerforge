# CareerForge environment — copy to .env and fill in values:  cp .env.example .env
# .env is gitignored; NEVER commit real values. Safe local defaults only here.
#
# API variables are zod-validated at boot (apps/api/src/env.ts — the single
# source of truth; a test asserts every schema key is documented in this file).

# ── Postgres (docker compose) ────────────────────────────────────────────
POSTGRES_USER=careerforge
POSTGRES_PASSWORD=generate-a-local-password
POSTGRES_DB=careerforge
POSTGRES_PORT=5432

# ── apps/api ─────────────────────────────────────────────────────────────
# development | test | production
NODE_ENV=development
# CareerForge uses the 4300 (web) / 4301 (api) pair: binventory — a permanent
# local service — owns :3000 and its neighborhood (relocated 2026-07-15).
API_PORT=4301
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Must match the POSTGRES_* values above.
DATABASE_URL=postgres://careerforge:generate-a-local-password@localhost:5432/careerforge
# Integration tests NEVER use DATABASE_URL directly: they derive it with the
# database name suffixed `_test` (careerforge_test), creating that DB on the
# same server as needed. Uncomment only to point tests somewhere else.
# TEST_DATABASE_URL=

# ── auth (M0-07, ADR-0007) ──────────────────────────────────────────────
# The single user, created at first boot iff no user has this email.
# NOTE: boot only reads AUTH_BOOTSTRAP_PASSWORD when first creating the user.
# After changing it, run `pnpm auth:sync-bootstrap` to apply the new value
# (re-hashes in place and revokes all sessions). Min 12 chars.
AUTH_BOOTSTRAP_EMAIL=you@example.com
AUTH_BOOTSTRAP_PASSWORD=generate-a-strong-password
# Browser origin allowed on mutating requests (CSRF origin check) AND the
# CORS allowlist (M0-10) — one definition of "the web app". Must match the
# apps/web dev server origin (nuxt.config.ts devServer.port), which the dev
# script's port preflight enforces (apps/web/scripts/assert-port-free.mjs).
WEB_APP_ORIGIN=http://localhost:4300

# apps/web (Nuxt reads NUXT_-prefixed vars into runtimeConfig at runtime).
# Where the SPA reaches the API; default matches API_PORT above.
NUXT_PUBLIC_API_BASE=http://localhost:4301
