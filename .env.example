# CareerForge environment — copy to .env and fill in values:  cp .env.example .env
# .env is gitignored; NEVER commit real values. Safe local defaults only here.
#
# API variables are zod-validated at boot (apps/api/src/env.ts — the single
# source of truth; a test asserts every schema key is documented in this file).

# ── Postgres (docker compose) ────────────────────────────────────────────
POSTGRES_USER=careerforge
POSTGRES_PASSWORD=generate-a-local-password
POSTGRES_DB=careerforge
POSTGRES_PORT=5432

# ── apps/api ─────────────────────────────────────────────────────────────
# development | test | production
NODE_ENV=development
API_PORT=3001
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Must match the POSTGRES_* values above.
DATABASE_URL=postgres://careerforge:generate-a-local-password@localhost:5432/careerforge
